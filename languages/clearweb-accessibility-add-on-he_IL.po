# ── Admin / Menu ────────────────────────────────────────────────────
msgid "Clearweb A11y"
msgstr "Clearweb נגישות"

msgid "You do not have permission to access this page."
msgstr "אין לך הרשאה לגשת לדף זה."

# ── Admin panel ──────────────────────────────────────────────────────
msgid "Clearweb Accessibility Add-on"
msgstr "תוסף הנגישות Clearweb"

msgid "The accessibility widget is an assistive layer. It does not replace semantic fixes, WCAG review, or legal/professional review."
msgstr "וידג'ט הנגישות הוא שכבת סיוע בלבד. הוא אינו מחליף תיקונים סמנטיים, בדיקת WCAG או ביקורת משפטית/מקצועית."

msgid "Need help fixing accessibility issues on your site? Clear Web offers audits, WCAG remediations, and ongoing support."
msgstr "זקוקים לעזרה בתיקוני נגישות באתר? Clear Web מציעה ביקורות נגישות, יישום WCAG וליווי שוטף."

msgid "Contact Clear Web"
msgstr "צרו קשר עם Clear Web"

msgid "Contact Clear Web for accessibility remediations (opens in a new tab)"
msgstr "צרו קשר עם Clear Web לתיקוני נגישות (נפתח בלשונית חדשה)"

msgid "Widget appearance"
msgstr "מראה הוידג'ט"

msgid "Control where the accessibility button appears on the public site."
msgstr "קבע היכן כפתור הנגישות יופיע באתר הציבורי."

msgid "Horizontal position"
msgstr "מיקום אופקי"

msgid "Left edge"
msgstr "צד שמאל"

msgid "Right edge"
msgstr "צד ימין"

msgid "Which side of the screen the trigger button is pinned to (physical left or right)."
msgstr "לאיזה צד המסך (שמאל או ימין פיזי) יוצמד כפתור הנגישות."

msgid "Vertical position (desktop)"
msgstr "מיקום אנכי (מחשב)"

msgid "Vertical position (mobile)"
msgstr "מיקום אנכי (נייד)"

msgid "Sets the CSS top position as a percentage of the viewport height. 50% is vertically centered."
msgstr "קובע את ערך ה-top ב-CSS כאחוז מגובה המסך. 50% ממרכז את הכפתור אנכית."

msgid "%d%%"
msgstr "%d%%"

msgid "Save settings"
msgstr "שמור הגדרות"

msgid "Saving…"
msgstr "שומר…"

msgid "Settings saved."
msgstr "ההגדרות נשמרו."

msgid "Could not save settings. Please try again."
msgstr "לא ניתן לשמור את ההגדרות. נסה שוב."

msgid "Loading settings…"
msgstr "טוען הגדרות…"

