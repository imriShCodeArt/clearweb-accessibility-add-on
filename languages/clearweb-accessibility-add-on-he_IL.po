# ── Statement generator ───────────────────────────────────────────────
msgid "Accessibility Statement for %s"
msgstr "הצהרת נגישות עבור %s"

msgid "We are committed to making this website accessible to people with disabilities."
msgstr "אנו מחויבים להנגיש אתר זה לאנשים עם מוגבלויות."

msgid "Accessibility adjustments"
msgstr "התאמות נגישות"

msgid "This draft should describe the accessibility work performed on the website, known limitations, and the review process."
msgstr "טיוטה זו צריכה לתאר את עבודת הנגישות שבוצעה באתר, מגבלות ידועות ותהליך הביקורת."

msgid "Contact"
msgstr "יצירת קשר"

msgid "If you find an accessibility issue, contact us at"
msgstr "אם מצאת בעיית נגישות, צור איתנו קשר בכתובת"

msgid "Last updated:"
msgstr "עודכן לאחרונה:"

# ── Legal docs ────────────────────────────────────────────────────────
msgid "Terms of Use"
msgstr "תנאי שימוש"

msgid "Privacy Policy"
msgstr "מדיניות פרטיות"

msgid "This draft applies to %s."
msgstr "טיוטה זו חלה על %s."

msgid "Replace this placeholder with AI-assisted generated sections after implementing the legal interview flow."
msgstr "החלף מציין מיקום זה בסעיפים שנוצרו בסיוע AI לאחר יישום תהליך הראיון המשפטי."

msgid "Important:"
msgstr "חשוב:"

msgid "This draft is not legal advice."
msgstr "טיוטה זו אינה ייעוץ משפטי."

# ── Scanner rules ─────────────────────────────────────────────────────
msgid "Image is missing an alt attribute."
msgstr "לתמונה חסר מאפיין alt."

msgid "Image has an empty alt attribute. Confirm it is decorative."
msgstr "לתמונה יש מאפיין alt ריק. ודא שהיא דקורטיבית."

msgid "Button has no accessible name."
msgstr "לכפתור אין שם נגיש."

# ── REST / misc ───────────────────────────────────────────────────────
msgid "Attachment is not an image."
msgstr "הקובץ המצורף אינו תמונה."

msgid "Invalid attachment ID."
msgstr "מזהה קובץ מצורף לא תקין."

msgid "Invalid scan ID."
msgstr "מזהה סריקה לא תקין."

msgid "No AI provider is configured."
msgstr "לא הוגדר ספק AI."

msgid "Missing API key."
msgstr "חסר מפתח API."

msgid "OpenAI client not implemented yet."
msgstr "לקוח OpenAI טרם יושם."

msgid "This is a draft and is not legal advice. Have a qualified lawyer review it before publication."
msgstr "זו טיוטה ואינה ייעוץ משפטי. יש לבקש מעורך דין מוסמך לבדוק אותה לפני פרסום."

msgid "This is a draft. A qualified accessibility professional should review it before publication."
msgstr "זו טיוטה. יש לבקש ממומחה נגישות מוסמך לבדוק אותה לפני פרסום."

